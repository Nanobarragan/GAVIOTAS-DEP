                            <option value="Disponible">🟢 Disponible</option>
                            <option value="Limitado">🟡 Limitado / Mantenimiento</option>
                            <option value="Interrupción">🔴 Interrupción</option>
                        </select>
                    </div>
                </div>

                <div class="bg-white p-4 rounded-xl space-y-3">
                    <h3 class="font-bold text-sm text-slate-700 border-b pb-1">Publicar Aviso Reciente</h3>
                    <input type="text" id="nuevoAvisoTexto" placeholder="Ej: Fumigación de jardines" class="w-full p-2 bg-slate-50 border rounded-lg text-xs">
                    <button onclick="agregarAviso()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg text-xs transition">
                        Publicar Aviso
