                        <i data-lucide="refresh-cw" class="w-3 h-3"></i> Actualizar vista
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="border border-slate-100 bg-slate-50/50 rounded-2xl p-6 space-y-4">
