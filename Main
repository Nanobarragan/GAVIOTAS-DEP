                    <div>
                        <label class="block text-xs text-slate-500 font-medium mb-1">Estado del Agua:</label>
                        <select id="adminAgua" class="w-full p-2 bg-slate-50 border rounded-lg text-xs" onchange="actualizarDesdeAdmin()">
                            <option value="Disponible">🟢 Disponible</option>
