    <script>
        // 1. DATOS INICIALES POR DEFECTO (Si la app se abre por primera vez)
        const datosInicialesDefecto = {
            agua: "Disponible",
            luz: "Disponible",
            ultimaActualizacion: "19 Jun 2026 • 10:34 PM",
            avisos: [
                { texto: "Recolección de basura extraordinaria", fecha: "19 Jun" },
                { texto: "Limpieza profunda de áreas comunes", fecha: "21 Jun" }
            ],
            historial: [
                { fecha: "19 Jun 2026, 10:34 PM", agua: "Disponible", luz: "Disponible", notas: "Sin incidencias reportadas. Todo en orden." },
                { fecha: "17 Jun 2026, 06:45 PM", agua: "Interrupción", luz: "Disponible", notas: "Fuga en línea principal. Servicio restablecido con éxito." },
                { fecha: "12 Jun 2026, 09:00 AM", agua: "Disponible", luz: "Limitado", notas: "Mantenimiento programado por CFE en transformador norte." }
            ]
        };

        // Cargar datos actuales desde localStorage o usar los de defecto
        let appData = JSON.parse(localStorage.getItem("lasGaviotasData")) || datosInicialesDefecto;

        // Guardar datos en el almacenamiento local
        function guardarDatos() {
            localStorage.setItem("lasGaviotasData", JSON.stringify(appData));
            inicializarApp();
        }

        // 2. RENDERIZADO COMPLETO DE LA INTERFAZ
        function inicializarApp(forzarAlerta = false) {
            if(forzarAlerta) alert("¡Datos actualizados desde el sistema residencial!");

            // Formatear estilos según el estado
            const estilosStatus = {
                "Disponible": { color: "text-green-600", bg: "bg-green-500", badge: "bg-green-50 text-green-700 border-green-200", descAgua: "Sin incidencias reportadas en la red de distribución interna.", descLuz: "Suministro general estable y plantas de emergencia listas." },
                "Limitado": { color: "text-amber-500", bg: "bg-amber-500", badge: "bg-amber-50 text-amber-700 border-amber-200", descAgua: "Presión reducida por mantenimiento preventivo en cisternas.", descLuz: "Baja tensión temporal reportada en el cuadrante." },
                "Interrupción": { color: "text-red-500", bg: "bg-red-500", badge: "bg-red-50 text-red-700 border-red-200", descAgua: "Corte temporal por reparación de tubería de suministro.", descLuz: "Interrupción del servicio general. Cuadrilla técnica trabajando." }
            };

            // Actualizar Widgets Superiores
            document.getElementById("widgetAguaBadge").className = `text-sm font-bold ${estilosStatus[appData.agua].color}`;
            document.getElementById("widgetAguaBadge").innerText = appData.agua;

            document.getElementById("widgetLuzBadge").className = `text-sm font-bold ${estilosStatus[appData.luz].color}`;
            document.getElementById("widgetLuzBadge").innerText = appData.luz;

            // Actualizar etiquetas de tiempo
            document.querySelectorAll(".timestamp-lbl").forEach(el => {
                el.innerHTML = `<i data-lucide="clock" class="w-3 h-3 inline"></i> Última actualización: ${appData.ultimaActualizacion}`;
            });

            // Actualizar Widget de Mantenimientos basados en el estado
            const maintWidget = document.getElementById("maintWidgetContent");
            if (appData.agua === "Disponible" && appData.luz === "Disponible") {
                maintWidget.innerHTML = `
                    <div class="inline-flex p-2 bg-green-50 text-green-600 rounded-full mb-1"><i data-lucide="check-circle" class="w-5 h-5"></i></div>
                    <p class="text-sm font-semibold text-slate-700">Sin mantenimientos activos</p>
                `;
            } else {
                maintWidget.innerHTML = `
                    <div class="inline-flex p-2 bg-amber-50 text-amber-600 rounded-full mb-1"><i data-lucide="alert-triangle" class="w-5 h-5"></i></div>
                    <p class="text-sm font-semibold text-slate-700">Atención: Ajustes en curso</p>
                `;
            }

            // Banner general de estado
            const banner = document.getElementById("generalStatusBanner");
            if (appData.agua === "Disponible" && appData.luz === "Disponible") {
                banner.className = "flex items-center gap-2 font-semibold text-sm mt-1 text-green-600";
                banner.innerHTML = `<i data-lucide="check-circle" class="w-4 h-4"></i> Todos los sistemas operando correctamente`;
            } else {
                banner.className = "flex items-center gap-2 font-semibold text-sm mt-1 text-amber-600";
                banner.innerHTML = `<i data-lucide="alert-circle" class="w-4 h-4"></i> Reporte de variaciones en los servicios`;
            }

            // Actualizar tarjetas detalladas principales
            document.getElementById("cardAguaBadge").className = `inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full border ${estilosStatus[appData.agua].badge}`;
            document.getElementById("cardAguaBadge").innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${estilosStatus[appData.agua].bg}"></span> ${appData.agua}`;
            document.getElementById("cardAguaDesc").innerText = estilosStatus[appData.agua].descAgua;

            document.getElementById("cardLuzBadge").className = `inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full border ${estilosStatus[appData.luz].badge}`;
            document.getElementById("cardLuzBadge").innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${estilosStatus[appData.luz].bg}"></span> ${appData.luz}`;
            document.getElementById("cardLuzDesc").innerText = estilosStatus[appData.luz].descLuz;

            // Renderizar la lista de Avisos
            const listaAvisosHTML = document.getElementById("listaAvisos");
            listaAvisosHTML.innerHTML = "";
            appData.avisos.slice(0, 3).forEach(aviso => {
                listaAvisosHTML.innerHTML += `
                    <li class="flex justify-between items-start gap-2 py-1 border-b border-slate-50">
                        <span>• ${aviso.texto}</span>
                        <span class="text-slate-400 whitespace-nowrap">${aviso.fecha}</span>
                    </li>
                `;
            });

            // Renderizar Tabla del Historial
            const tablaBody = document.getElementById("tablaHistorialBody");
            tablaBody.innerHTML = "";
            appData.historial.forEach((item, index) => {
                const badgeAgua = `<span class="${item.agua === 'Disponible' ? 'text-green-600' : item.agua === 'Limitado' ? 'text-amber-500' : 'text-red-500'} font-bold">● ${item.agua}</span>`;
                const badgeLuz = `<span class="${item.luz === 'Disponible' ? 'text-green-600' : item.luz === 'Limitado' ? 'text-amber-500' : 'text-red-500'} font-bold">● ${item.luz}</span>`;
                
                tablaBody.innerHTML += `
                    <tr class="${index % 2 === 1 ? 'bg-slate-50/40' : ''}">
                        <td class="p-4 font-medium text-slate-800">${item.fecha}</td>
                        <td class="p-4">${badgeAgua}</td>
                        <td class="p-4">${badgeLuz}</td>
                        <td class="p-4 text-slate-500">${item.notes || item.notas}</td>
                    </tr>
                `;
            });

            // Sincronizar campos del panel administrador con el estado actual
            document.getElementById("adminAgua").value = appData.agua;
            document.getElementById("adminLuz").value = appData.luz;

            // Re-renderizar iconos de Lucide cargados dinámicamente
            lucide.createIcons();
        }

        // 3. FUNCIONES DE ADMINISTRACIÓN
        function toggleAdminPanel() {
            const panel = document.getElementById("adminPanel");
            panel.classList.toggle("hidden");
            
            // Mostrar u ocultar elementos extra de administrador en la interfaz
            document.querySelectorAll(".admin-element").forEach(el => {
                el.classList.toggle("hidden", panel.classList.contains("hidden"));
            });
        }

        function obtenerFechaActualFormateada() {
            const meses = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            const ahora = new Date();
            const dia = ahora.getDate();
            const mes = meses[ahora.getMonth()];
            const anio = ahora.getFullYear();
            let horas = ahora.getHours();
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const ampm = horas >= 12 ? 'PM' : 'AM';
            horas = horas % 12;
            horas = horas ? horas : 12; // Formato 12 horas
            return `${dia} ${mes} ${anio} • ${horas}:${minutos} ${ampm}`;
        }

        function actualizarDesdeAdmin() {
            appData.agua = document.getElementById("adminAgua").value;
            appData.luz = document.getElementById("adminLuz").value;
            appData.ultimaActualizacion = obtenerFechaActualFormateada();
            guardarDatos();
        }

        function agregarAviso() {
            const input = document.getElementById("nuevoAvisoTexto");
            if (!input.value.trim()) return alert("Escribe un aviso válido.");
            
            const ahora = new Date();
            const fechaCorta = `${ahora.getDate()} ${["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][ahora.getMonth()]}`;
            
            appData.avisos.unshift({ texto: input.value.trim(), fecha: fechaCorta });
            input.value = "";
            guardarDatos();
        }

        function registrarEnHistorial() {
            const notasInput = document.getElementById("histNotas");
            if (!notasInput.value.trim()) return alert("Por favor agrega una nota descriptiva para el historial.");

            appData.historial.unshift({
                fecha: obtenerFechaActualFormateada(),
                agua: appData.agua,
                luz: appData.luz,
                notas: notasInput.value.trim()
            });

            notasInput.value = "";
            guardarDatos();
        }

        function borrarHistorial() {
            if(confirm("¿Seguro que deseas reiniciar el historial de la app?")) {
                appData.historial = [];
                guardarDatos();
            }
        }

        // Ejecutar al iniciar la página
        window.onload = () => inicializarApp();
    </script>
</body>
</html>
